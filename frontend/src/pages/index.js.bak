              <Link href="/mercado" className="text-gray-600 hover:text-green-600 px-3 py-2 rounded-md text-sm font-medium">
                Mercado
              </Link>
              {isAuthenticated ? (
                <>
                  <Link href={user.tipo === 'produtor' ? '/produtor/dashboard' : '/comprador/dashboard'} className="text-gray-600 hover:text-green-600 px-3 py-2 rounded-md text-sm font-medium">
