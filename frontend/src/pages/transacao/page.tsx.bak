import { useState, useEffect } from 'react';
import Head from 'next/head';
import { useRouter } from 'next/router';
import ProtectedRoute from '../../components/ProtectedRoute';
import { useAuth } from '../../hooks/useAuth';
import toast from 'react-hot-toast';

function TransacaoDetalhesPage() {
  const [transacao, setTransacao] = useState(null);
  const [loading, setLoading] = useState(true);
  const router = useRouter();
  const { id } = router.query;

  useEffect(() => {
    if (id) {
      fetchTransacao();
    }
  }, [id]);

  const fetchTransacao = async () => {
    setLoading(true);
    try {
      const res = await fetch(`/api/transacao/${id}`);
      const data = await res.json();
      if (data.ok) {
        setTransacao(data.transacao);
      } else {
        toast.error(data.message);
        router.push('/'); // Redireciona se não tiver acesso
      }
    } catch (err) {
      toast.error('Erro de conexão.');
    } finally {
      setLoading(false);
    }
  };

  if (loading || !transacao) return <div className="p-8 text-center">Carregando...</div>;

  return (
    <div className="min-h-screen bg-gray-100">
      <Head>
        <title>Detalhes da Transação | AgroKongo</title>
      </Head>
      <div className="container mx-auto px-4 py-8">
        <h1 className="text-3xl font-bold text-gray-900 mb-2">Detalhes da Transação</h1>
        <p className="text-gray-600 mb-6">Referência: {transacao.fatura_ref}</p>

        <div className="bg-white p-6 rounded-lg shadow">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h3 className="font-semibold text-gray-700">Produto</h3>
              <p>{transacao.safra.produto.nome}</p>
            </div>
            <div>
              <h3 className="font-semibold text-gray-700">Status</h3>
              <p className="font-bold">{transacao.status.replace('_', ' ')}</p>
            </div>
            <div>
              <h3 className="font-semibold text-gray-700">Quantidade</h3>
              <p>{transacao.quantidade_comprada} kg</p>
            </div>
            <div>
              <h3 className="font-semibold text-gray-700">Valor Total</h3>
              <p>{new Intl.NumberFormat('pt-AO', { style: 'currency', currency: 'AOA' }).format(transacao.valor_total_pago)}</p>
            </div>
            <div>
              <h3 className="font-semibold text-gray-700">Vendedor</h3>
              <p>{transacao.vendedor.nome}</p>
            </div>
            <div>
              <h3 className="font-semibold text-gray-700">Comprador</h3>
              <p>{transacao.comprador.nome}</p>
            </div>
          </div>

          {/* Adicionar timeline de status e outras ações aqui */}
          <div className="mt-8 pt-6 border-t border-gray-200">
            <h3 className="text-xl font-semibold text-gray-800 mb-4">Ações</h3>
            {/* Botões de ação (abrir disputa, avaliar, etc.) viriam aqui */}
            <p className="text-gray-500">Funcionalidades de disputa e avaliação em desenvolvimento.</p>
          </div>
        </div>
      </div>
    </div>
  );
}

export default function TransacaoDetalhes() {
  return (
    <ProtectedRoute>
      <TransacaoDetalhesPage />
    </ProtectedRoute>
  );
}
